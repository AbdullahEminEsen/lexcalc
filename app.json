{
  "expo": {
    "name": "LexCalc",
    "slug": "lexcalc",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
    "resizeMode": "contain",
    "backgroundColor": "#0D0F14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lexcalc.app"
    },
    "android": {
      "package": "com.lexcalc.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0D0F14"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "scheme": "lexcalc",
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0F14",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c8839d9b-a250-4a0a-9994-b4858242600f"
      }
    }
  }
}
